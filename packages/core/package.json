{
  "name": "@voiceform/core",
  "version": "0.1.0",
  "description": "Headless, voice-driven form engine with pluggable STT adapters and optional default UI",
  "type": "module",
  "license": "MIT",
  "author": "Corey Schuman",
  "repository": {
    "type": "git",
    "url": "https://github.com/cschuman/voice-form.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/cschuman/voice-form#readme",
  "bugs": {
    "url": "https://github.com/cschuman/voice-form/issues"
  },
  "keywords": [
    "voice",
    "form",
    "speech-to-text",
    "stt",
    "voice-ui",
    "web-speech-api",
    "headless",
    "accessibility",
    "a11y"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.cjs"
    },
    "./detect-schema": {
      "types": "./dist/detect-schema.d.ts",
      "import": "./dist/detect-schema.mjs",
      "require": "./dist/detect-schema.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
