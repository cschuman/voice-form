{
  "name": "@voiceform/svelte",
  "version": "0.1.0",
  "description": "Svelte 5 component wrapper for @voiceform/core voice-driven forms",
  "type": "module",
  "license": "MIT",
  "author": "Corey Schuman",
  "repository": {
    "type": "git",
    "url": "https://github.com/cschuman/voice-form.git",
    "directory": "packages/svelte"
  },
  "homepage": "https://github.com/cschuman/voice-form#readme",
  "bugs": {
    "url": "https://github.com/cschuman/voice-form/issues"
  },
  "keywords": [
    "voice",
    "form",
    "svelte",
    "svelte5",
    "speech-to-text",
    "stt",
    "voice-ui",
    "component"
  ],
  "svelte": "./src/VoiceForm.svelte",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./VoiceForm.svelte": {
      "svelte": "./src/VoiceForm.svelte",
      "default": "./src/VoiceForm.svelte"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "@voiceform/core": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@voiceform/core": "workspace:*",
    "jsdom": "^29.0.1",
    "svelte": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
