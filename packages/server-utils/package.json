{
  "name": "@voiceform/server-utils",
  "version": "0.1.0",
  "description": "Server-side utilities for voice-form BYOE (Bring Your Own Endpoint) handlers",
  "type": "module",
  "license": "MIT",
  "author": "Corey Schuman",
  "repository": {
    "type": "git",
    "url": "https://github.com/cschuman/voice-form.git",
    "directory": "packages/server-utils"
  },
  "homepage": "https://github.com/cschuman/voice-form#readme",
  "bugs": {
    "url": "https://github.com/cschuman/voice-form/issues"
  },
  "keywords": [
    "voice",
    "form",
    "server",
    "llm",
    "speech-to-text",
    "prompt",
    "byoe",
    "endpoint"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@voiceform/core": "workspace:*"
  },
  "devDependencies": {
    "@voiceform/core": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
